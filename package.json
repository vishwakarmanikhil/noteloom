{
  "name": "@notevo/block-editor",
  "version": "0.1.0",
  "description": "Zero-runtime-dependency React block editor",
  "license": "MIT",
  "type": "module",
  "main": "./dist/block-editor.cjs.js",
  "module": "./dist/block-editor.es.js",
  "exports": {
    ".": {
      "import": "./dist/block-editor.es.js",
      "require": "./dist/block-editor.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config examples/basic/vite.config.js",
    "build": "vite build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^18.3.0",
    "react-dom": "^18.2.0 || ^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
