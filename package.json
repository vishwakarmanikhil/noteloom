{
  "name": "noteloom",
  "version": "0.1.3",
  "description": "Zero-runtime-dependency, React-first block/rich-text editor — Notion-style blocks, inline widgets, slash commands, undo/redo, and clipboard, with an optional default theme (noteloom/style.css).",
  "keywords": [
    "react",
    "editor",
    "rich-text",
    "block-editor",
    "wysiwyg",
    "contenteditable",
    "notion",
    "slash-commands"
  ],
  "license": "MIT",
  "author": "Nikhil Vishwakarma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishwakarmanikhil/noteloom.git"
  },
  "bugs": {
    "url": "https://github.com/vishwakarmanikhil/noteloom/issues"
  },
  "homepage": "https://noteloom.qusere.in",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/noteloom.cjs",
  "module": "./dist/noteloom.es.js",
  "style": "./dist/style.css",
  "exports": {
    ".": {
      "import": "./dist/noteloom.es.js",
      "require": "./dist/noteloom.cjs",
      "default": "./dist/noteloom.es.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --config examples/basic/vite.config.js",
    "build": "vite build && node -e \"require('fs').copyFileSync('src/style.css','dist/style.css')\"",
    "test": "vitest run",
    "prepublishOnly": "npm test && npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
